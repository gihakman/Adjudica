# Adjudica — environment template (no secrets committed)
# Copy to .env and fill in values. .env is gitignored.

# Funded GenLayer Bradbury testnet private key used only to sign deploy/seed txs.
# 0x-prefixed 32-byte hex. Read in code via process.env only. Never commit.
ACCOUNT_PRIVATE_KEY=

# Optional protocol config.
# Address that receives protocol fees on settlement. Blank = the deployer address.
FEE_RECIPIENT=
# Protocol fee in basis points (100 = 1.00%). Default 100 if unset.
FEE_BPS=100
